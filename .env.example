# OptimusAI Environment Configuration
# Copy to .env and fill in values

# App
APP_NAME=OptimusAI
DEBUG=true
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql+asyncpg://optimus:optimus@localhost:5432/optimusai

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth (CHANGE IN PRODUCTION)
JWT_SECRET_KEY=your-secret-key-change-me
ENCRYPTION_KEY=your-fernet-key-change-me

# Storage (MinIO)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=optimusai

# Facebook
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_WEBHOOK_VERIFY_TOKEN=optimus-verify-token

# WhatsApp
WHATSAPP_WEBHOOK_VERIFY_TOKEN=optimus-wa-verify

# LLM
OLLAMA_BASE_URL=http://localhost:11434
ANTHROPIC_API_KEY=
DEFAULT_LLM_PROVIDER=ollama

# Embeddings
EMBEDDING_MODEL=BAAI/bge-m3

# CORS
CORS_ORIGINS=["http://localhost:3000"]
